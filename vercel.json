{
  "version": 2,
  "buildCommand": "cd frontend && npm run build && cd ..",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/(auth|fetch-content|generate-exam|generate-exam-questions|docs|openapi.json)(.*)",
      "destination": "/api/index.py"
    }
  ],
  "routes": [
    {
      "src": "/(auth|fetch-content|generate-exam|generate-exam-questions|docs|openapi.json)(.*)",
      "dest": "/api/index.py",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
